nrow = dims[1], ncol = dims[2]
)
X_noisy <- X
X_noisy[noise_mask] <- X_noisy[noise_mask] + shift_matrix[noise_mask]
X_noisy[X_noisy < 0] <- 0
X_noisy[X_noisy > 4] <- 4
changes <- data.frame(
row = row(noise_mask)[noise_mask],
col = col(noise_mask)[noise_mask],
old = X[noise_mask],
new = X_noisy[noise_mask]
)
print(changes)
return(X_noisy)
}
