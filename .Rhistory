# load TOXSWA output
lines <- readLines("SwashProjects/Test_surface_water/TOXSWA/9.sum", encoding = "latin1")
# implement function to read the application part of .SUM files
read_application_data <- function(line_data){
lines_application <- substring(line_data[c(46:49)],3) # remove first two characters
lines_application <- gsub(" {3,}", "\t", lines_application) #transform 3 or more white spaces into tab
data_application <- read.table(
text = lines_application,
header = TRUE,  sep = "\t")
colnames(data_application) <- c("application Date", "Mass (a.i./ha)","Areic mean deposition (mg/m^2)")
return(data_application)
}
# implement function to read the concentration part of .SUM files
read_concentration_data <- function(line_data){
lines_concentration <- gsub(" {3,}", "\t", line_data[c(241:253)]) #transform 3 or more white spaces into tab
data_water_conc <- read.table(
text = lines_concentration,, sep = "\t")
colnames(data_water_conc) <- c("Measure", "Concentration (ug/L)", "Date", "Daynumber")
data_water_conc$Date <- substr(data_water_conc$Date, start = 1, stop = 11)
return(data_water_conc)
}
print(read_application_data(lines))
concentration_data <- read_concentration_data(lines)
# plot concentration over time
ggplot(concentration_data[-2,])+
geom_path(aes(x = as.Date(Date, format = "%d-%b-%Y"), y = `Concentration (µg/L)`))+
scale_x_date(date_breaks = "2 weeks", date_labels = "%d-%m")+
labs(x = "Date")+
theme_classic()
