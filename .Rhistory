ggplot(data = part_c_plot)+
geom_point(aes(x = factor(LOCATION, level = part_c$LOCATION), y = concentration, colour = Substance), size = 2.5)+
theme_classic()+
theme(axis.text.x = element_text(angle = 45, vjust = 0.5))+
labs(x = "Location", y = "Concentration (µg/L)")+
scale_colour_discrete(labels = c("Parent compound", "1st Metabolite", "2nd Metabolite"))
