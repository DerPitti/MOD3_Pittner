# test predict
add_noise_ordinal <- function(X, p = 0.1) {
X_noisy <- X
noise_mask <- matrix(runif(length(X)) < p, nrow = nrow(X))
shift <- matrix(sample(c(-1, 1), length(X), replace = TRUE), nrow = nrow(X))
X_noisy[noise_mask] <- X_noisy[noise_mask] + shift[noise_mask]
# keep within bounds 0–4
X_noisy[X_noisy < 0] <- 0
X_noisy[X_noisy > 4] <- 4
return(X_noisy)
}
