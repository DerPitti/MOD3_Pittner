# test predict
add_noise_ordinal <- function(X, p = 0.1) {
X <- as.matrix(X)
dims <- dim(X)
shifts <- c(-1, 0, 1)
probs  <- c(0.25, 0.5, 0.25)
shift_matrix <- matrix(
sample(shifts, length(X), replace = TRUE, prob = probs),
nrow = dims[1], ncol = dims[2]
)
noise_mask <- matrix(
runif(length(X)) < p,
nrow = dims[1], ncol = dims[2]
)
X_noisy <- X
X_noisy[noise_mask] <- X_noisy[noise_mask] + shift_matrix[noise_mask]
X_noisy[X_noisy < 0] <- 0
X_noisy[X_noisy > 4] <- 4
changes <- data.frame(
row = row(noise_mask)[noise_mask],
col = colnames(x)[col(noise_mask)[noise_mask]],
old = X[noise_mask],
new = X_noisy[noise_mask]
)
changes <- changes[-changes[3]==changes[4],]
print(changes)
return(X_noisy)
}
# test predict
add_noise_ordinal <- function(X, p = 0.1) {
X <- as.matrix(X)
dims <- dim(X)
shifts <- c(-1, 0, 1)
probs  <- c(0.25, 0.5, 0.25)
shift_matrix <- matrix(
sample(shifts, length(X), replace = TRUE, prob = probs),
nrow = dims[1], ncol = dims[2]
)
noise_mask <- matrix(
runif(length(X)) < p,
nrow = dims[1], ncol = dims[2]
)
X_noisy <- X
X_noisy[noise_mask] <- X_noisy[noise_mask] + shift_matrix[noise_mask]
X_noisy[X_noisy < 0] <- 0
X_noisy[X_noisy > 4] <- 4
changes <- data.frame(
row = row(noise_mask)[noise_mask],
col = colnames(x)[col(noise_mask)[noise_mask]],
old = X[noise_mask],
new = X_noisy[noise_mask]
)
changes <- changes[-(changes[3]==changes[4]),]
print(changes)
return(X_noisy)
}
test_predict_noise <- add_noise_ordinal(test_predict[,-1])
